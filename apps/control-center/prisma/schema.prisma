generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("free") @db.VarChar(20)
  accounts      Account[]
  sessions      Session[]
  
  monitors      monitors[]
  proxy_groups  proxy_groups[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model monitors {
  id         Int       @id @default(autoincrement())
  
  userId     String    
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  query      String    @db.VarChar(255)
  price_min  Int?
  price_max  Int?
  size_id    String?   @db.VarChar(50)
  catalog_ids String?  @db.VarChar(500)
  brand_ids  String?   @db.VarChar(500)
  color_ids  String?   @db.VarChar(500)
  region     String    @default("de") @db.VarChar(10)
  status     String?   @default("active") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  items      items[]
  discord_webhook String?
  webhook_active  Boolean  @default(true)

  proxy_group_id Int?
  proxy_group    proxy_groups? @relation(fields: [proxy_group_id], references: [id], onDelete: SetNull)
}

model items {
  id         BigInt    @id
  monitor_id Int?
  title      String?   @db.VarChar(500)
  price      String?   @db.VarChar(50)
  size       String?   @db.VarChar(100)
  condition  String?   @db.VarChar(100)
  location    String?
  rating     String?   @db.VarChar(50)
  url        String?
  image_url  String?
  found_at   DateTime? @default(now()) @db.Timestamp(6)
  monitors   monitors? @relation(fields: [monitor_id], references: [id], onDelete: Cascade)
}

model proxy_groups {
  id         Int       @id @default(autoincrement())
  
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String    @db.VarChar(100)
  proxies    String    @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(6)
  monitors   monitors[]
}
