# =============================================================================
# Vintrack Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# --- Discord OAuth (for NextAuth login) ---
# Create an app at https://discord.com/developers/applications
# Set the OAuth2 redirect URL to: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID=your_discord_client_id
AUTH_DISCORD_SECRET=your_discord_client_secret
AUTH_URL=https://...
DASHBOARD_URL=https://...

# --- OIDC Authentication (optional, replaces Discord, e.g. Authentik, Google, Keycloak) ---
# Set these to use an OIDC provider instead of Discord.
# When set, Discord login is disabled and only OIDC is used.
# Existing Discord accounts are not automatically linked to OIDC accounts.
# The callback URL must be: {AUTH_URL}/api/auth/callback/oidc
# AUTH_OIDC_ISSUER=https://your-oidc-provider.com/application/o/your-app/
# AUTH_OIDC_CLIENT_ID=your_oidc_client_id
# AUTH_OIDC_CLIENT_SECRET=your_oidc_client_secret
# AUTH_OIDC_NAME=Authentik

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here

# --- Vinted Session Storage ---
# Generate with: openssl rand -base64 32
VINTED_SESSION_ENCRYPTION_KEY=your_random_session_encryption_key_here

# --- Browser Extension Compatibility ---
# Latest version shown as available; minimum version hard-blocks extension actions.
BROWSER_EXTENSION_LATEST_VERSION=0.1.3
BROWSER_EXTENSION_MIN_VERSION=0.1.3

# --- Database (default values match docker-compose.yml) ---
# Only override these if you changed the postgres settings
# POSTGRES_USER=vinuser
# POSTGRES_PASSWORD=vinpassword
# POSTGRES_DB=vintrack

# --- Worker ---
# Per-monitor query delay is configured in the dashboard.
# CHECK_INTERVAL_MS is only a legacy fallback for invalid monitor rows.
# PROXY_FILE=proxies.txt
# Set VINTED_FETCH_MODE=mock for frontend/dev testing without real Vinted requests.
# VINTED_FETCH_MODE=live
# VINTED_MOCK_SCENARIO=new-items
# VINTED_MOCK_DROP_INTERVAL_MS=3000
# Hybrid discovery defaults off. Start in shadow mode and review metrics before active alerts.
# DISCOVERY_MODE=off
# Shadow mode includes free proxies for measurement. Active free alerts require explicit opt-in.
# DISCOVERY_ALLOW_FREE_ACTIVE=false
# DISCOVERY_INTERVAL_MS=500
# DISCOVERY_FREE_INTERVAL_MS=500
# DISCOVERY_PER_PAGE=96
# DISCOVERY_FREE_PER_PAGE=64
# DISCOVERY_MAX_BACKFILL_PAGES=3
# DISCOVERY_FREE_CLIENT_POOL_SIZE=8
# DISCOVERY_FREE_TIMEOUT_MS=3000
# DISCOVERY_FREE_HEDGE_DELAY_MS=150
# Dedicated proxy sessions should stay on one exit IP for the lifetime of a client.
# CLIENT_POOL_SIZE=5
# TLS_PROFILE=chrome_144
# CATALOG_TIMEOUT_MS=2000
# CATALOG_HEDGE_DELAY_MS=250
# ALERT_WORKERS=8
# DISCORD_ALERT_WORKERS=8
# TELEGRAM_ALERT_WORKERS=16
# ENRICHMENT_WORKERS=8
# DETECTION_RETENTION_DAYS=14
# Pre-index ID sampling is an isolated, shadow-only experiment. It never sends alerts.
# ID_SCANNER_ENABLED=false
# Enable the optional Compose service with COMPOSE_PROFILES=preindex.
# COMPOSE_PROFILES=preindex
# ID_SCANNER_REGION=de
# ID_SCANNER_STRIDE=100
# ID_SCANNER_INTERVAL_MS=500
# ID_SCANNER_JITTER_MS=200
# ID_SCANNER_TIMEOUT_MS=2000
# ID_SCANNER_POOL_SIZE=16
# Leaves the highest-ranked free proxies to canonical and hybrid monitoring.
# ID_SCANNER_PROXY_OFFSET=32
# ID_SCANNER_STUCK_SKIP_AFTER=10
# ID_SCANNER_MAX_AHEAD=10000
# PREINDEX_PROBE_RETENTION_HOURS=48
# PREINDEX_SAMPLE_RETENTION_DAYS=14

# --- Telegram Notifications ---
# Create a bot with @BotFather and paste the token here.
# Users connect Telegram from the dashboard with a one-time code; the token stays server-side.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Public bot username without @, used to open Telegram from the dashboard.
TELEGRAM_BOT_USERNAME=your_bot_username
# Optional: pass this when calling Telegram setWebhook and Vintrack will verify it.
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
# One-time setup after deploy:
# curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook?url=https://your-domain.com/api/telegram/webhook&secret_token=$TELEGRAM_WEBHOOK_SECRET"
